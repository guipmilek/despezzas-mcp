# Opcional. Token ID do Firebase copiado de uma sessão web autenticada do Despezzas.
# Prefira DESPEZZAS_EMAIL/DESPEZZAS_PASSWORD/DESPEZZAS_FIREBASE_API_KEY ou a página local /login
# para renovação automática.
DESPEZZAS_TOKEN=

# Opcional. Usado para fazer login em https://api.despezzas.com/v2/auth e obter
# uma sessão Firebase sem copiar bearer tokens manualmente. Exige DESPEZZAS_FIREBASE_API_KEY.
DESPEZZAS_EMAIL=
DESPEZZAS_PASSWORD=

# Opcional. O padrão é %USERPROFILE%\.despezzas-mcp\session.json.
# Defina como "none" para desativar a persistência de sessão.
DESPEZZAS_SESSION_FILE=

# Obrigatório para login por e-mail/senha e renovação de sessão Firebase.
# Não há valor padrão neste repositório público.
# É uma chave pública do Firebase Web — o próprio frontend do Despezzas a expõe.
# Para obtê-la, abra o site do Despezzas (https://despezzas.com), inspecione o
# código-fonte (F12 > Sources) e procure por "apiKey" nos arquivos JavaScript.
DESPEZZAS_FIREBASE_API_KEY=

# Opcional. O padrão é https://api.despezzas.com.
DESPEZZAS_API_BASE_URL=https://api.despezzas.com

# Opcional. Use "stdio" para clientes MCP locais ou "http" para clientes remotos/estilo App.
MCP_TRANSPORT=stdio

# Opcional quando MCP_TRANSPORT=http.
HOST=127.0.0.1
PORT=8787

# Segredo compartilhado opcional para modo HTTP. Clientes que não usam ChatGPT podem enviar:
# Authorization: Bearer <MCP_HTTP_BEARER_TOKEN>
MCP_HTTP_BEARER_TOKEN=

# Obrigatório para OAuth do ChatGPT por túneis/produção. Exemplo: https://abc.ngrok.app
MCP_PUBLIC_BASE_URL=

# Hostnames opcionais separados por vírgula aceitos pela validação do header Host
# no servidor HTTP. O hostname de MCP_PUBLIC_BASE_URL é adicionado automaticamente.
MCP_ALLOWED_HOSTS=

# Tempo de vida opcional do token de acesso OAuth do servidor MCP.
MCP_OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600

# Fortemente recomendado para deploys remotos. Use um segredo longo e aleatório para
# verificar o token de acesso MCP do ChatGPT depois de reinícios/suspensões do serviço.
MCP_OAUTH_TOKEN_SECRET=

# Obrigatório para deploys públicos em Cloudflare Workers e recomendado para qualquer
# deploy HTTP público. Este é o código de proprietário digitado na tela de login MCP
# antes de o servidor autorizar o ChatGPT a acessar sua conta Despezzas.
MCP_OWNER_AUTH_CODE=

# Obrigatório para o modo multiusuário em Cloudflare Workers. Usado para criptografar
# a sessão de refresh Firebase/Despezzas de cada usuário antes de gravá-la no Workers KV.
SESSION_ENCRYPTION_KEY=
