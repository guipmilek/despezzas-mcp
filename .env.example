# Optional. Firebase ID token copied from an authenticated Despezzas web session.
# Prefer DESPEZZAS_EMAIL/DESPEZZAS_PASSWORD or the local /login page for auto-refresh.
DESPEZZAS_TOKEN=

# Optional. Used to login through https://api.despezzas.com/v2/auth and obtain
# a Firebase session without manually copying bearer tokens.
DESPEZZAS_EMAIL=
DESPEZZAS_PASSWORD=

# Optional. Defaults to %USERPROFILE%\.despezzas-mcp\session.json.
# Set to "none" to disable session persistence.
DESPEZZAS_SESSION_FILE=

# Optional. Defaults to Despezzas frontend Firebase API key discovered from the public bundle.
DESPEZZAS_FIREBASE_API_KEY=

# Optional. Defaults to https://api.despezzas.com.
DESPEZZAS_API_BASE_URL=https://api.despezzas.com

# Optional. Use "stdio" for local MCP clients or "http" for remote/App-style clients.
MCP_TRANSPORT=stdio

# Optional when MCP_TRANSPORT=http.
HOST=127.0.0.1
PORT=8787

# Optional shared secret for HTTP mode. Non-ChatGPT clients can send:
# Authorization: Bearer <MCP_HTTP_BEARER_TOKEN>
MCP_HTTP_BEARER_TOKEN=

# Required for ChatGPT OAuth over tunnels/production. Example: https://abc.ngrok.app
MCP_PUBLIC_BASE_URL=

# Optional comma-separated hostnames accepted by the HTTP server Host header
# validation. MCP_PUBLIC_BASE_URL hostname is added automatically.
MCP_ALLOWED_HOSTS=

# Optional OAuth access-token lifetime for the MCP server token.
MCP_OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600

# Strongly recommended for remote deployments. Use a long random secret so
# ChatGPT's MCP access token can be verified after service restarts/sleeps.
MCP_OAUTH_TOKEN_SECRET=
