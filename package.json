{
  "name": "despezzas-mcp",
  "version": "0.1.0",
  "description": "Servidor MCP para uma conta financeira pessoal do Despezzas.",
  "type": "module",
  "license": "MIT",
  "author": "Guilherme Milek",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guipmilek/despezzas-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/guipmilek/despezzas-mcp/issues"
  },
  "homepage": "https://github.com/guipmilek/despezzas-mcp#readme",
  "keywords": [
    "mcp",
    "despezzas",
    "finance",
    "chatgpt"
  ],
  "bin": {
    "despezzas-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "dev:cloudflare": "wrangler dev --local",
    "dev:http": "cross-env MCP_TRANSPORT=http tsx src/index.ts",
    "check:cloudflare": "wrangler deploy --dry-run",
    "deploy:cloudflare": "wrangler deploy",
    "check:mcp-tools": "node scripts/check-mcp-tools.mjs",
    "check:repo-safety": "node scripts/check-repo-safety.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "inspect:har": "node scripts/inspect-har.mjs",
    "lint": "eslint .",
    "start": "node dist/index.js",
    "start:http": "cross-env MCP_TRANSPORT=http node dist/index.js",
    "smoke:readonly": "npm run build && node scripts/smoke-readonly.mjs",
    "test": "npm run build && node --test test/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "verify": "npm run check:repo-safety && npm run check:mcp-tools && npm run format:check && npm run lint && npm run typecheck && npm test",
    "session:checkpoint": "node scripts/session-manager.mjs checkpoint",
    "session:resume": "node scripts/session-manager.mjs resume"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "hono": "^4.12.27",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260701.1",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.62.1",
    "wrangler": "^4.106.0"
  }
}
